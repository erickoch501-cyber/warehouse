<Window x:Class="WarehouseApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор организации"
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите организацию" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox x:Name="OrganizationsList" Grid.Row="1" DisplayMemberPath="OrgName"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Открыть склад" Width="100" Click="OpenWarehouse_Click"/>
        </StackPanel>
    </Grid>
</Window>