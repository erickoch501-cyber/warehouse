<Window x:Class="WarehouseApp.Views.WarehouseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад"
        Height="280" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Название склада" 
                   FontWeight="Bold" 
                   Margin="0,0,0,5"/>

        <TextBox x:Name="WhNameTextBox" 
                 Grid.Row="1"
                 Height="30"
                 Padding="5"
                 FontSize="14"
                 Margin="0,0,0,15"/>

        <TextBlock Text="Адрес склада" 
                   Grid.Row="2"
                   FontWeight="Bold" 
                   Margin="0,0,0,5"/>

        <TextBox x:Name="WhAddressTextBox" 
                 Grid.Row="3"
                 Height="30"
                 Padding="5"
                 FontSize="14"
                 Margin="0,0,0,15"/>

        <TextBlock x:Name="ErrorTextBlock"
                   Grid.Row="4"
                   Text="Название и адрес не могут быть пустыми"
                   Foreground="Red"
                   Visibility="Collapsed"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="80" Height="30"
                    Background="#4CAF50" 
                    Foreground="White"
                    Click="OkButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="Отмена"
                    Width="80" Height="30"
                    Margin="10,0,0,0"
                    Background="#555" 
                    Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>