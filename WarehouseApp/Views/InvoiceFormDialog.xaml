<Window x:Class="WarehouseApp.Views.InvoiceFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Накладная"
        Height="700" Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Тип накладной -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Тип накладной:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <ComboBox x:Name="TypeCombo" Width="150" SelectedIndex="0">
                <ComboBoxItem Content="Поступление" Tag="Incoming"/>
                <ComboBoxItem Content="Списание" Tag="Outgoing"/>
            </ComboBox>
        </StackPanel>

        <!-- Существующие товары на складе -->
        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Выбрать существующий товар:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ExistingProductCombo" Grid.Row="1" Height="30" 
                          DisplayMemberPath="Name" 
                          SelectionChanged="ExistingProductCombo_SelectionChanged"/>
            </Grid>
        </Border>

        <!-- Форма добавления/редактирования товара -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Наименование:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,5" TextChanged="NameBox_TextChanged"/>

                <TextBlock Text="Категория:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="CategoryBox" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,5"/>

                <TextBlock Text="Производитель:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="ManufacturerBox" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,5"/>

                <TextBlock Text="Поставщик:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="SupplierBox" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,5"/>

                <TextBlock Text="Цена:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="PriceBox" Grid.Row="0" Grid.Column="3" Height="30" Margin="5,5,0,5"/>

                <TextBlock Text="Количество:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="QuantityBox" Grid.Row="1" Grid.Column="3" Height="30" Margin="5,5,0,5"/>

                <TextBlock Text="Скидка %:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="DiscountBox" Grid.Row="2" Grid.Column="3" Height="30" Margin="5,5,0,5" Text="0"/>

                <TextBlock Text="Фото:" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="3" Grid.Column="3" Orientation="Horizontal" Margin="5,5,0,5">
                    <TextBox x:Name="ImagePathBox" Width="150" Height="30" IsReadOnly="True"/>
                    <Button Content="Обзор" Width="60" Margin="5,0,0,0" Click="Browse_Click"/>
                </StackPanel>

                <TextBlock x:Name="ExistingProductHint" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                           Foreground="Green" Visibility="Collapsed" Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- Кнопка добавления товара в список -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить товар в накладную" Width="180" Click="AddItem_Click"/>
        </StackPanel>

        <!-- Таблица товаров в накладной -->
        <DataGrid x:Name="ItemsGrid" Grid.Row="4" AutoGenerateColumns="False" Height="200" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="80"/>
                <DataGridTextColumn Header="Скидка" Binding="{Binding Discount}" Width="60"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding IsNew}" Width="60"/>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Click="RemoveItem_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Ошибка и кнопки -->
        <TextBlock x:Name="ErrorText" Grid.Row="5" Foreground="Red" Visibility="Collapsed" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Создать накладную" Width="130" Margin="0,0,10,0" Click="Ok_Click"/>
            <Button Content="Отмена" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>