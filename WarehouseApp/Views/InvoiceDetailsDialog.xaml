<Window x:Class="WarehouseApp.Views.InvoiceDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали накладной"
        Height="400" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Номер:" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Margin="5"/>
        <TextBlock x:Name="NumberTextBlock" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Дата:" FontWeight="Bold" Grid.Row="1" Grid.Column="0" Margin="5"/>
        <TextBlock x:Name="DateTextBlock" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Тип:" FontWeight="Bold" Grid.Row="2" Grid.Column="0" Margin="5"/>
        <TextBlock x:Name="TypeTextBlock" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Товары:" FontWeight="Bold" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>

        <DataGrid x:Name="ItemsGrid" Grid.Row="3" Grid.Column="1" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="5"
                  Height="200">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="200"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Закрыть" Width="100" Height="30" Margin="5" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>