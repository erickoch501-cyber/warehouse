<Window x:Class="WarehouseApp.Views.InvoiceAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить накладную"
        Height="300" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Тип" FontWeight="Bold"/>
        <ComboBox x:Name="TypeCombo" Grid.Row="1" Height="30" Margin="0,5,0,15">
            <ComboBoxItem Content="Поступление" Tag="Incoming"/>
            <ComboBoxItem Content="Списание" Tag="Outgoing"/>
        </ComboBox>

        <TextBlock Text="Товар" FontWeight="Bold" Grid.Row="2"/>
        <ComboBox x:Name="ProductCombo" Grid.Row="3" Height="30" Margin="0,5,0,15" DisplayMemberPath="Name"/>

        <TextBlock Text="Количество" FontWeight="Bold" Grid.Row="4"/>
        <TextBox x:Name="QuantityBox" Grid.Row="5" Height="30" Margin="0,5,0,15"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="Ok_Click"/>
            <Button Content="Отмена" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>